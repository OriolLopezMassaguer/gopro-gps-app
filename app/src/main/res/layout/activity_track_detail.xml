<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="300dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Distance" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDistance" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Max Speed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvMaxSpeed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Avg Speed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvAvgSpeed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Max Altitude" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvMaxAlt" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Altitude Gain" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvAltGain" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:text="Duration" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="11sp" />
                    <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speed (km/h)"
                android:textStyle="bold"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartSpeed"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Altitude (m)"
                android:textStyle="bold"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartAltitude"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="4dp" />

            <Button
                android:id="@+id/btnExportGpx"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:text="@string/export_gpx"
                android:enabled="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
